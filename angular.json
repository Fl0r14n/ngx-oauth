{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "newProjectRoot": "projects",
  "projects": {
    "ngx-oauth": {
      "projectType": "library",
      "root": "projects/ngx-oauth",
      "sourceRoot": "projects/ngx-oauth",
      "prefix": "lib",
      "architect": {
        "build": {
          "builder": "@angular/build:ng-packagr",
          "options": {
            "project": "projects/ngx-oauth/ng-package.json"
          },
          "configurations": {
            "production": {
              "tsConfig": "projects/ngx-oauth/tsconfig.lib.prod.json"
            },
            "development": {
              "tsConfig": "projects/ngx-oauth/tsconfig.lib.json"
            }
          },
          "defaultConfiguration": "production"
        },
        "lint": {
          "builder": "@angular-eslint/builder:lint",
          "options": {
            "lintFilePatterns": [
              "projects/ngx-oauth/**/*.ts",
              "projects/ngx-oauth/**/*.html"
            ],
            "eslintConfig": "projects/ngx-oauth/eslint.config.js"
          }
        },
        "test": {
          "builder": "@angular/build:unit-test",
          "options": {
            "buildTarget": "ngx-oauth-sample:build:development",
            "tsConfig": "projects/ngx-oauth/tsconfig.spec.json",
            "runner": "vitest",
            "providersFile": "projects/ngx-oauth/test-providers.ts",
            "include": ["**/*.spec.ts"]
          }
        }
      }
    },
    "ngx-oauth-sample": {
      "projectType": "application",
      "schematics": {
        "@schematics/angular:component": {
          "style": "scss"
        }
      },
      "root": "projects/ngx-oauth-sample",
      "sourceRoot": "projects/ngx-oauth-sample/src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular/build:application",
          "options": {
            "outputPath": "dist/ngx-oauth-sample",
            "index": "projects/ngx-oauth-sample/src/index.html",
            "browser": "projects/ngx-oauth-sample/src/main.ts",
            "polyfills": [],
            "tsConfig": "projects/ngx-oauth-sample/tsconfig.app.json",
            "inlineStyleLanguage": "scss",
            "assets": [
              "projects/ngx-oauth-sample/src/favicon.ico",
              "projects/ngx-oauth-sample/src/assets"
            ],
            "styles": [
              "projects/ngx-oauth-sample/src/styles.scss"
            ],
            "stylePreprocessorOptions": {
              "sass": {
                "silenceDeprecations": ["import", "global-builtin", "color-functions"]
              }
            },
            "scripts": [],
            "server": "projects/ngx-oauth-sample/src/main.server.ts",
            "prerender": true,
            "ssr": {
              "entry": "projects/ngx-oauth-sample/server.ts"
            }
          },
          "configurations": {
            "production": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "500kb",
                  "maximumError": "1mb"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "2kb",
                  "maximumError": "4kb"
                }
              ],
              "outputHashing": "all"
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular/build:dev-server",
          "options": {
            "ssl": true
          },
          "configurations": {
            "production": {
              "buildTarget": "ngx-oauth-sample:build:production"
            },
            "development": {
              "buildTarget": "ngx-oauth-sample:build:development"
            }
          },
          "defaultConfiguration": "development"
        },
        "extract-i18n": {
          "builder": "@angular/build:extract-i18n",
          "options": {
            "buildTarget": "ngx-oauth-sample:build"
          }
        },
        "test": {
          "builder": "@angular/build:karma",
          "options": {
            "polyfills": [],
            "tsConfig": "projects/ngx-oauth-sample/tsconfig.spec.json",
            "inlineStyleLanguage": "scss",
            "assets": [
              "projects/ngx-oauth-sample/src/favicon.ico",
              "projects/ngx-oauth-sample/src/assets"
            ],
            "styles": [
              "projects/ngx-oauth-sample/src/styles.scss"
            ],
            "scripts": []
          }
        },
        "lint": {
          "builder": "@angular-eslint/builder:lint",
          "options": {
            "lintFilePatterns": [
              "projects/ngx-oauth-sample/**/*.ts",
              "projects/ngx-oauth-sample/**/*.html"
            ],
            "eslintConfig": "projects/ngx-oauth-sample/eslint.config.js"
          }
        }
      }
    }
  },
  "cli": {
    "analytics": false
  },
  "schematics": {
    "@schematics/angular:component": {
      "type": "component"
    },
    "@schematics/angular:directive": {
      "type": "directive"
    },
    "@schematics/angular:service": {
      "type": "service"
    },
    "@schematics/angular:guard": {
      "typeSeparator": "."
    },
    "@schematics/angular:interceptor": {
      "typeSeparator": "."
    },
    "@schematics/angular:module": {
      "typeSeparator": "."
    },
    "@schematics/angular:pipe": {
      "typeSeparator": "."
    },
    "@schematics/angular:resolver": {
      "typeSeparator": "."
    }
  }
}
